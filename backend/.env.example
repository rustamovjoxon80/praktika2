# PostgreSQL ulanish manzili.
# O'zingizning PG Admin / PostgreSQL serveringiz ma'lumotlari bilan almashtiring:
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/quickbite_db?schema=public"

# Server porti
PORT=5000

# JWT xavfsizlik kaliti (o'zingiz xohlagan qiyin so'z yozishingiz mumkin)
JWT_SECRET="super_secret_quickbite_key_2026"
